# Ollama runs locally — no API key. Install: https://ollama.com
# Then: ollama pull llama3.2   (or another model from https://ollama.com/library)

OLLAMA_BASE_URL=http://127.0.0.1:11434
# Preferred model; if not installed, the app picks another model you have (e.g. mistral:latest).
OLLAMA_MODEL=llama3.2

# Max new tokens in the response (higher = longer JSON; needs more RAM)
OLLAMA_NUM_PREDICT=8192
