# --- Local: Ollama (default when no cloud API key) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_NUM_PREDICT=8192

# --- Cloud: Groq (recommended for Railway — fast, OpenAI-compatible) ---
# Key from https://console.groq.com/keys — only GROQ_API_KEY is required:
GROQ_API_KEY=gsk_...
# Defaults if unset: OPENAI_BASE_URL=https://api.groq.com/openai/v1
#                     OPENAI_MODEL=llama-3.3-70b-versatile
# Optional overrides:
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.1-8b-instant
# OPENAI_MODEL=openai/gpt-oss-120b

# --- Cloud: OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- Cloud: OpenRouter (uses OPENAI_API_KEY for the router key) ---
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_APP_NAME=AI Use Case Finder
